# Trip Log Compliance System - Environment Variables Reference
# Copy this file to .env and fill in the required values

# Django Security
SECRET_KEY=your-secure-random-key-here
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS settings (comma-separated URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.com

# Geoapify API
GEOAPIFY_API_KEY=your-geoapify-api-key-here
GEOAPIFY_TIMEOUT=5
GEOAPIFY_AUTOCOMPLETE_LIMIT=5

# Logging
LOG_LEVEL=INFO

# DRF Rate Limiting
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=120/min

# SSL/HTTPS (set to True for production)
DJANGO_SECURE_SSL_REDIRECT=False
